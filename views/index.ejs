<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sierra Nevada Properties Dashboard</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E🏔️%3C/text%3E%3C/svg%3E">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .header {
            background: white;
            border-radius: 12px;
            padding: 40px 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            text-align: center;
        }
        
        .header h1 {
            font-size: 2.5em;
            color: #2d3748;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        
        .header p {
            color: #718096;
            font-size: 1.1em;
            margin-bottom: 15px;
        }
        
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .stat-box {
            background: #f7fafc;
            padding: 15px;
            border-radius: 8px;
            border-left: 4px solid #667eea;
        }
        
        .stat-box strong {
            color: #2d3748;
            display: block;
            font-size: 1.8em;
            margin-bottom: 5px;
        }
        
        .stat-box small {
            color: #718096;
            font-size: 0.9em;
        }
        
        .filters-section {
            background: white;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        
        .filters-section h2 {
            color: #2d3748;
            margin-bottom: 20px;
            font-size: 1.3em;
        }
        
        .filter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }
        
        .filter-group {
            display: flex;
            flex-direction: column;
        }
        
        .filter-group label {
            color: #4a5568;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95em;
        }
        
        .filter-group input,
        .filter-group select {
            padding: 10px;
            border: 2px solid #e2e8f0;
            border-radius: 6px;
            font-size: 1em;
            transition: all 0.3s;
        }
        
        .filter-group input:focus,
        .filter-group select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
        
        .filter-actions {
            display: flex;
            gap: 10px;
        }
        
        button {
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1em;
        }
        
        .btn-filter {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            flex: 1;
        }
        
        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        
        .btn-reset {
            background: #e2e8f0;
            color: #2d3748;
        }
        
        .btn-reset:hover {
            background: #cbd5e0;
        }
        
        .results-info {
            color: #718096;
            font-size: 0.95em;
            margin-top: 15px;
        }
        
        .properties-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        
        .property-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }
        
        .property-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }
        
        .property-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: start;
        }
        
        .property-type {
            font-size: 0.85em;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }
        
        .property-score {
            background: rgba(255,255,255,0.2);
            padding: 8px 12px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 1.1em;
        }
        
        .property-score.excellent { background: rgba(52, 211, 153, 0.3); }
        .property-score.good { background: rgba(59, 130, 246, 0.3); }
        .property-score.fair { background: rgba(251, 191, 36, 0.3); }
        .property-score.poor { background: rgba(239, 68, 68, 0.3); }
        
        .property-body {
            padding: 20px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }
        
        .property-title {
            font-size: 1.1em;
            color: #2d3748;
            margin-bottom: 10px;
            font-weight: 600;
            line-height: 1.4;
            min-height: 2.8em;
        }
        
        .property-price {
            font-size: 1.4em;
            color: #667eea;
            font-weight: bold;
            margin-bottom: 12px;
        }
        
        .property-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .detail {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #4a5568;
            font-size: 0.95em;
        }
        
        .detail strong {
            color: #2d3748;
        }
        
        .detail-icon {
            font-size: 1.2em;
        }
        
        .property-location {
            color: #718096;
            font-size: 0.95em;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        
        .property-links {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: auto;
        }
        
        .property-links a {
            display: inline-block;
            padding: 10px;
            background: #f0f4f8;
            color: #667eea;
            text-decoration: none;
            border-radius: 6px;
            font-size: 0.9em;
            font-weight: 600;
            text-align: center;
            transition: all 0.3s;
            border: 2px solid transparent;
        }
        
        .property-links a:hover {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #718096;
        }
        
        .empty-state-icon {
            font-size: 4em;
            margin-bottom: 20px;
        }
        
        .empty-state h3 {
            color: #4a5568;
            margin-bottom: 10px;
        }
        
        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.8em;
            }
            
            .header {
                padding: 25px 20px;
            }
            
            .properties-grid {
                grid-template-columns: 1fr;
            }
            
            .filter-grid {
                grid-template-columns: 1fr;
            }
            
            .stats {
                grid-template-columns: 1fr 1fr;
            }
            
            .property-details {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>
                <span>🏔️</span>
                Sierra Nevada Properties
            </h1>
            <p>Dashboard con los mejores apartamentos encontrados</p>
            
            <div class="stats">
                <div class="stat-box">
                    <strong><%= totalProperties %></strong>
                    <small>Propiedades totales</small>
                </div>
                <div class="stat-box">
                    <strong><%= filteredCount %></strong>
                    <small>Resultados filtrados</small>
                </div>
                <div class="stat-box">
                    <strong>€<%= avgPrice.toLocaleString('es-ES') %></strong>
                    <small>Precio promedio</small>
                </div>
            </div>
        </div>
        
        <!-- Filters -->
        <div class="filters-section">
            <h2>🔍 Filtros</h2>
            <form method="GET" action="/" id="filterForm">
                <div class="filter-grid">
                    <div class="filter-group">
                        <label for="minPrice">Precio mínimo (€)</label>
                        <input type="number" id="minPrice" name="minPrice" min="0" value="<%= filters.minPrice %>" step="10000">
                    </div>
                    <div class="filter-group">
                        <label for="maxPrice">Precio máximo (€)</label>
                        <input type="number" id="maxPrice" name="maxPrice" value="<%= filters.maxPrice %>" step="10000">
                    </div>
                    <div class="filter-group">
                        <label for="minScore">Score mínimo</label>
                        <input type="number" id="minScore" name="minScore" min="1" max="10" step="0.5" value="<%= filters.minScore %>">
                    </div>
                    <div class="filter-group">
                        <label for="zone">Zona/Localidad</label>
                        <select id="zone" name="zone">
                            <option value="">Todas las zonas</option>
                            <% zones.forEach(z => { %>
                                <option value="<%= z %>" <%= filters.zone === z ? 'selected' : '' %>>
                                    <%= z %>
                                </option>
                            <% }); %>
                        </select>
                    </div>
                </div>
                
                <div class="filter-actions">
                    <button type="submit" class="btn-filter">🔍 Filtrar</button>
                    <button type="reset" class="btn-reset" onclick="document.getElementById('filterForm').reset(); location.href='/'">Limpiar</button>
                </div>
                
                <div class="results-info">
                    Mostrando <strong><%= filteredCount %></strong> de <strong><%= totalProperties %></strong> propiedades
                </div>
            </form>
        </div>
        
        <!-- Properties Grid -->
        <% if (properties.length > 0) { %>
            <div class="properties-grid">
                <% properties.forEach(prop => { %>
                    <div class="property-card">
                        <div class="property-header">
                            <div>
                                <div class="property-type"><%= prop.title.split(' ').slice(0, 1).join(' ') %></div>
                            </div>
                            <div class="property-score <%= prop.score >= 8 ? 'excellent' : prop.score >= 6.5 ? 'good' : prop.score >= 5 ? 'fair' : 'poor' %>">
                                <%= prop.score %>/10
                            </div>
                        </div>
                        
                        <div class="property-body">
                            <h3 class="property-title"><%= prop.title %></h3>
                            <div class="property-price"><%= prop.priceStr %></div>
                            
                            <div class="property-details">
                                <div class="detail">
                                    <span class="detail-icon">🛏️</span>
                                    <div><strong><%= prop.bedrooms %></strong> hab</div>
                                </div>
                                <div class="detail">
                                    <span class="detail-icon">🚿</span>
                                    <div><strong><%= prop.bathrooms %></strong> baños</div>
                                </div>
                                <% if (prop.size > 0) { %>
                                    <div class="detail">
                                        <span class="detail-icon">📐</span>
                                        <div><strong><%= prop.size %></strong> m²</div>
                                    </div>
                                <% } %>
                            </div>
                            
                            <div class="property-location">
                                <span>📍</span>
                                <span><%= prop.location %></span>
                            </div>
                            
                            <div class="property-links">
                                <a href="<%= prop.url %>" target="_blank">Ver en Pisos.com</a>
                                <a href="https://www.inmobiliario.es" target="_blank">Inmobiliario.es</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">🔍</div>
                <h3>No se encontraron propiedades</h3>
                <p>Ajusta los filtros e intenta nuevamente</p>
            </div>
        <% } %>
    </div>
</body>
</html>
